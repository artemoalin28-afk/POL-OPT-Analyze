# Local environment template for PolyOpt
# Copy to .env and replace placeholder values:
#   cp .env.local.example .env
#
# Required for boot: DATABASE_URL, SESSION_SECRET (when APP_TIER=pro in production)
# NODE_ENV is set by npm scripts (dev → development, start → production)

# --- Database ---

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/poly_opt

# --- Server ---

PORT=5003
APP_TIER=pro

# Long random string; required for Pro + production (not the dev default)
SESSION_SECRET=replace-with-a-long-random-secret

# --- Polymarket ---

# Public Polygon address — powers portfolio / market feeds
POLY_ADDRESS=0xYourPolygonWalletAddress
POLYMARKET_PRIVATE_KEY=

# CLOB L2 credentials (from derive-poly-key.ts)
POLY_API_KEY=
POLY_PASSPHRASE=
POLY_SECRET=

# --- Frontend (Vite — baked in at build time) ---

VITE_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# --- Optimizer (Python CVaR via server/optimize.py) ---

# Recommended: use uv (run `uv sync` once in repo root)
OPTIMIZER_CMD=uv
OPTIMIZER_ARGS=run python server/optimize.py

# Alternative without uv:
# OPTIMIZER_CMD=python
# OPTIMIZER_ARGS=server/optimize.py
# (requires: pip install -e .  or  pip install numpy cvxpy pandas pydantic scipy)
